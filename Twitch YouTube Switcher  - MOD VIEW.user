// ==UserScript==
// @name         Twitch YouTube Switcher - MOD VIEW
// @namespace    http://tampermonkey.net/
// @version      1.0
// @description  Adds a YouTube stream switcher for Twitch MOD VIEW.
// @author       Pheesher
// @match        https://www.twitch.tv/*
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    let lastUsedUrl = "";

    const YT_ICON = `<svg width="20" height="20" viewBox="0 0 24 24" fill="#ff0000"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`;
    const TWITCH_ICON = `<svg width="18" height="18" viewBox="0 0 24 24" fill="#9147ff"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/></svg>`;

    function getYouTubeID(url) {
        const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
        const match = url.match(regExp);
        return (match && match[2].length === 11) ? match[2] : url;
    }

    function createUI() {
        if (document.getElementById('yt-switcher-btn')) return null;

        const container = document.createElement('div');
        container.id = 'yt-sidebar-container';
        // Reduced padding to eliminate the "big gap" in the stack
        container.style = 'display: flex; flex-direction: column; align-items: center; width: 100%; padding-bottom: 8px;';

        const btn = document.createElement('button');
        btn.id = 'yt-switcher-btn';
        btn.innerHTML = YT_ICON;
        // EXACT PILL MATCH: 48px width, 30px height, 6px radius
        btn.style = 'background: rgba(255, 255, 255, 0.1); border: none; height: 30px; width: 48px; display: flex; align-items: center; justify-content: center; cursor: pointer; border-radius: 6px; transition: background 0.1s; outline: none;';

        btn.onmouseenter = () => btn.style.background = 'rgba(255, 255, 255, 0.2)';
        btn.onmouseleave = () => btn.style.background = 'rgba(255, 255, 255, 0.1)';

        const popup = document.createElement('div');
        popup.id = 'yt-switcher-popup';
        popup.style = 'display: none; position: fixed; background: #18181b; border: 1px solid #3f3f46; border-radius: 8px; padding: 12px; z-index: 10001; width: 260px; box-shadow: 0 4px 20px rgba(0,0,0,0.9);';

        const input = document.createElement('input');
        input.placeholder = 'Paste YouTube URL...';
        input.value = lastUsedUrl;
        // Centered text and standard Twitch input styling
        input.style = 'width: 100%; height: 32px; background: #000; color: #fff; border: 1px solid #3f3f46; border-radius: 4px; padding: 0 10px; font-size: 13px; margin-bottom: 10px; outline: none; text-align: center;';

        const goBtn = document.createElement('button');
        goBtn.innerText = 'SWAP TO YOUTUBE';
        goBtn.style = 'width: 100%; background: #e91916; color: white; border: none; height: 32px; font-weight: bold; cursor: pointer; border-radius: 4px; font-size: 11px; text-transform: uppercase; display: flex; align-items: center; justify-content: center;';

        popup.appendChild(input);
        popup.appendChild(goBtn);
        document.body.appendChild(popup);
        container.appendChild(btn);

        btn.onclick = (e) => {
            const mask = document.getElementById('yt-local-mask');
            if (mask) {
                mask.remove();
                const video = document.querySelector('video');
                if (video) { video.muted = false; video.play(); }
                btn.innerHTML = YT_ICON;
                return;
            }

            const rect = btn.getBoundingClientRect();
            popup.style.left = (rect.right + 12) + 'px';
            popup.style.top = rect.top + 'px';

            popup.style.display = popup.style.display === 'block' ? 'none' : 'block';
            if (popup.style.display === 'block') input.focus();
        };

        document.addEventListener('mousedown', (e) => {
            if (!btn.contains(e.target) && !popup.contains(e.target)) popup.style.display = 'none';
        });

        goBtn.onclick = (e) => {
            const val = input.value.trim();
            const player = document.querySelector('.mod-view-video-player__video-container') || document.querySelector('.video-player__container');
            const video = document.querySelector('video');
            if (!val || !player || !video) return;

            lastUsedUrl = val;
            const mask = document.createElement('div');
            mask.id = 'yt-local-mask';
            mask.style = 'position:absolute; inset:0; background:#000; z-index:10000;';
            mask.innerHTML = `<iframe src="https://www.youtube.com/embed/${getYouTubeID(val)}?autoplay=1" style="width:100%; height:100%; border:none;" allow="autoplay; fullscreen"></iframe>`;

            video.muted = true; video.pause();
            player.appendChild(mask);
            popup.style.display = 'none';
            btn.innerHTML = TWITCH_ICON;
        };

        return container;
    }

    const inject = () => {
        // Targeted dock widget stack
        const widgetStack = document.querySelector('[data-highlight-selector="dock"]');
        if (!widgetStack || document.getElementById('yt-sidebar-container')) return;

        const ui = createUI();
        if (ui) widgetStack.appendChild(ui);
    };

    const observer = new MutationObserver(inject);
    observer.observe(document.body, { childList: true, subtree: true });
})();